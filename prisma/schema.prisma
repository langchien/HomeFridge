// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  ADMIN
  MEMBER
  DEVICE
  HOMEMAKER
}

enum StorageLocation {
  FREEZER
  CHILLER
  FRIDGE_SHELF
  VEGETABLE_DRAWER
  DOOR_SHELF
  PANTRY
}

enum MealTime {
  BREAKFAST // Bữa sáng
  LUNCH // Bữa trưa
  DINNER // Bữa tối
}

enum MenuStatus {
  PLANNED // Đã lên kế hoạch
  COOKING // Đang nấu
  DONE // Hoàn thành
  CANCELLED // Đã hủy
}

enum FridgeItemStatus {
  FRESH // Tươi mới (>3 ngày)
  EXPIRING_SOON // Sắp hết hạn (1-3 ngày)
  EXPIRED // Đã hết hạn (<1 ngày)
}

// ─── Models ──────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  name      String
  role      Role     @default(MEMBER)
  avatar    String?
  phone     String?
  email     String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menuPlans MenuPlan[]
}

model Category {
  id          String       @id @default(uuid())
  name        String       @unique
  icon        String?
  description String?
  ingredients Ingredient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ingredient {
  id                  String   @id @default(uuid())
  name                String   @unique
  image               String?
  categoryId          String
  category            Category @relation(fields: [categoryId], references: [id])
  unit                String   @default("g")
  storageInstructions String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipeIngredients RecipeIngredient[]
  fridgeItems       FridgeItem[]
}

// ─── Công thức nấu ăn ────────────────────────────────────

model Recipe {
  id           String   @id @default(uuid())
  title        String
  thumbnail    String?
  description  String?
  prepTime     Int? // Thời gian chuẩn bị (phút)
  cookTime     Int? // Thời gian nấu (phút)
  servings     Int? // Số khẩu phần (người)
  instructions String[] // ["Bước 1: Ngâm ốc...", "Bước 2: Luộc ốc...", "Bước 3: Xào bơ..."]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ingredients RecipeIngredient[]
  menuPlans   MenuPlan[]
}

model RecipeIngredient {
  id           String     @id @default(uuid())
  recipeId     String
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  quantity     Int
}

// ─── Thực đơn theo tuần ──────────────────────────────────

model MenuPlan {
  id       String     @id @default(uuid())
  date     DateTime // Ngày của thực đơn (lưu theo UTC, chỉ dùng phần ngày)
  mealTime MealTime // BREAKFAST | LUNCH | DINNER
  status   MenuStatus @default(PLANNED)
  note     String? // Ghi chú tùy chọn

  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Quản lý tủ lạnh ────────────────────────────────────

model FridgeItem {
  id              String           @id @default(uuid())
  ingredientId    String
  ingredient      Ingredient       @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  quantity        Float // Số lượng hiện tại
  unit            String // Đơn vị (g, ml, piece, quả, bó, chai, etc.)
  storageLocation StorageLocation // Vị trí lưu trữ trong tủ
  expiryDate      DateTime // Ngày hết hạn
  status          FridgeItemStatus // Trạng thái (FRESH, EXPIRING_SOON, EXPIRED)

  addedAt   DateTime @default(now())
  updatedAt DateTime @updatedAt
}
