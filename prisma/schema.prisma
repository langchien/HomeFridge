// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  ADMIN
  MEMBER
  DEVICE
  HOMEMAKER
}

enum StorageLocation {
  FREEZER
  CHILLER
  FRIDGE_SHELF
  VEGETABLE_DRAWER
  DOOR_SHELF
  PANTRY
}

enum MealTime {
  LUNCH  // Bữa trưa
  DINNER // Bữa tối
}

enum MenuStatus {
  PLANNED   // Đã lên kế hoạch
  COOKING   // Đang nấu
  DONE      // Hoàn thành
  CANCELLED // Đã hủy
}

enum MenuRequestStatus {
  PENDING  // Chờ duyệt
  APPROVED // Đã duyệt
  REJECTED // Từ chối
}

// ─── Models ──────────────────────────────────────────────

model User {
  id        String       @id @default(uuid())
  username  String       @unique
  password  String
  name      String
  role      Role         @default(MEMBER)
  avatar    String?
  phone     String?
  email     String?      @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  requests  MenuRequest[]
}

model Category {
  id          String       @id @default(uuid())
  name        String       @unique
  icon        String?
  description String?
  ingredients Ingredient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ingredient {
  id                  String   @id @default(uuid())
  name                String   @unique
  image               String?
  categoryId          String
  category            Category @relation(fields: [categoryId], references: [id])
  unit                String   @default("g")
  storageInstructions String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipeIngredients RecipeIngredient[]
}

// ─── Công thức nấu ăn ────────────────────────────────────

model Recipe {
  id          String   @id @default(uuid())
  name        String
  image       String?
  description String?
  prepTime    Int?     // Thời gian chuẩn bị (phút)
  cookTime    Int?     // Thời gian nấu (phút)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ingredients RecipeIngredient[]
  menuItems   DailyMenuItem[]
  requests    MenuRequest[]
}

model RecipeIngredient {
  id           String     @id @default(uuid())
  recipeId     String
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  quantity Float
  unit     String

  createdAt DateTime @default(now())
}

// ─── Menu ngày ───────────────────────────────────────────

model DailyMenu {
  id     String     @id @default(uuid())
  date   DateTime   @db.Date
  status MenuStatus @default(PLANNED)
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items DailyMenuItem[]

  @@unique([date]) // Mỗi ngày chỉ có 1 DailyMenu
}

model DailyMenuItem {
  id          String    @id @default(uuid())
  dailyMenuId String
  dailyMenu   DailyMenu @relation(fields: [dailyMenuId], references: [id], onDelete: Cascade)
  recipeId    String
  recipe      Recipe    @relation(fields: [recipeId], references: [id])
  mealTime    MealTime
  servings    Int       @default(1) // Số phần ăn (để scale nguyên liệu)

  createdAt DateTime @default(now())
}

// ─── Yêu cầu từ thành viên ───────────────────────────────

model MenuRequest {
  id       String  @id @default(uuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipeId String?
  recipe   Recipe? @relation(fields: [recipeId], references: [id])

  dishName String            // Tên món đề xuất
  note     String?           // Ghi chú của thành viên
  mealTime MealTime?         // Buổi mong muốn
  date     DateTime? @db.Date // Ngày mong muốn
  status   MenuRequestStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
